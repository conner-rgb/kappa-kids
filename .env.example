# Copy this file to `.env` and fill in real values.
# Never commit your real .env to source control.

# --- Stripe (required for real payments) ---
# Get your keys at: https://dashboard.stripe.com/test/apikeys
# You need BOTH the secret key (sk_test_...) and the publishable key (pk_test_...).
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# Set this after you run `stripe listen --forward-to localhost:3000/webhook/stripe`
# The CLI prints a webhook signing secret starting with `whsec_`.
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# --- Server ---
PORT=3000
# The URL the app is reachable at. Stripe redirects back here after payment.
PUBLIC_URL=http://localhost:3000

# --- Event configuration (edit to match your event) ---
EVENT_NAME=Kappa Kids
EVENT_DESCRIPTION=Bringing Kappa sisters and their children together for friendship, fun, and a new generation of shared traditions.
EVENT_PRICE_CENTS=3000
EVENT_CURRENCY=usd
# Leave EVENT_CAPACITY blank for unlimited.
EVENT_CAPACITY=
# Leave EVENT_DATE blank if there isn't a specific date.
EVENT_DATE=
# Optional human-readable price label (shown next to the price). Leave blank to auto-format.
EVENT_PRICE_LABEL=$30 / year (includes 3 events annually)

# --- Confirmation emails (Resend) ---
# Sign up at https://resend.com, then API Keys -> Create API Key.
# RESEND_FROM accepts "Display Name <email@domain.com>" or a plain email.
# Use onboarding@resend.dev if you don't have a verified domain yet.
RESEND_API_KEY=
RESEND_FROM=Kappa Kids <onboarding@resend.dev>
# When a parent hits "Reply" on the confirmation email, it'll go to this address.
# Gmail / Yahoo / Outlook addresses are fine here (unlike RESEND_FROM).
RESEND_REPLY_TO=

# --- Admin ---
# If set, the admin page requires ?token=... in the URL (or Bearer header).
# If unset, the admin page is only reachable from localhost.
ADMIN_TOKEN=
